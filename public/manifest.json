{
  "name": "Highlark - Screenshot Annotator",
  "description": "The lightweight open-source screenshot annotator. Capture, annotate, and share.",
  "version": "1.0.3",
  "manifest_version": 3,
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_title": "Capture and annotate screenshots",
    "default_popup": "popup/index.html"
  },
  "options_page": "options/index.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "storage",
    "windows",
    "downloads"
  ],
  "web_accessible_resources": [
    {
      "resources": ["annotate/index.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
